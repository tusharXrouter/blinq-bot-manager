# =====================================================
# SECRETS — All secrets below can be omitted from this file.
# If missing, the bot will prompt interactively at startup.
# For Docker, use Docker secrets at /run/secrets/<name>.
# =====================================================

# Owner wallet private key (with funds - USDC and MON)
# Omit to enter at runtime. Docker secret name: owner_private_key
# OWNER_PRIVATE_KEY=

# Keystore passphrase for encrypting wallet private keys at rest (REQUIRED)
# All private keys in wallets.json are encrypted with AES-256-GCM + Argon2id
# On first run, existing plaintext keys are auto-migrated to encrypted
# WARNING: If you lose this passphrase, encrypted keys cannot be recovered
# Omit to enter at runtime. Docker secret name: keystore_passphrase
# KEYSTORE_PASSPHRASE=

# PostgreSQL connection URL for wallet storage
# Format: postgres://user:password@host:port/dbname?sslmode=disable
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Hasura GraphQL endpoint
HASURA_URL=https://beta.api.blinq.fi/graph/v1/graphql

# Hermes/Pyth price oracle URL (public default; replace with a paid gateway
# for production use to avoid rate limiting)
HERMES_URL=https://hermes.pyth.network/v2/updates/price/latest

# Single wallet mode (use owner wallet directly, no wallet creation/funding)
# Set to "true" to enable, "false" or omit to disable
SINGLE_WALLET_MODE=false

# Generate new wallets on-the-fly during betting (default: true)
# Set to "false" to only use existing wallets from store (pre-generated via --generate)
# Note: --generate flag still works even when this is false (for initial setup)
GENERATE_NEW_WALLETS=true

# Cooldown between bets in seconds (optional - overrides config.yaml)
# Default: 30 seconds
COOLDOWN_SECONDS=30

# Mnemonic for deterministic wallet generation (optional)
# If provided, wallets will be generated from this seed.
# Omit to enter at runtime when --generate is used. Docker secret name: mnemonic
# MNEMONIC=

# Initial wallet count to generate/ensure from mnemonic (optional)
INITIAL_WALLET_COUNT=10

# Number of concurrent betting threads (optional)
# Default: 1
THREADS=1

# Referral Code to redeem for new wallets (optional)
# Supports comma-separated list - one will be randomly selected per wallet
# Example: REFERRAL_CODE=CODE1,CODE2,CODE3
REFERRAL_CODE=

# Backend API Base URL for auth/referral services
API_BASE_URL=https://beta.api.blinq.fi

# =====================================================
# BOT MANAGER CONFIGURATION
# Used by: ./bot-manager (unified entry point)
# Runs bet-bot + candle-rush-bot + periodic sweep
# Config in config.yaml under "manager:" section
# =====================================================

# Manager is configured via config.yaml:
#   manager:
#     enabled_bots: ["bet-bot", "candle-rush-bot"]
#     sweep_interval_hours: 8
#
# All secrets above (OWNER_PRIVATE_KEY, KEYSTORE_PASSPHRASE, MNEMONIC)
# are collected once at startup and shared across all bots.

# =====================================================
# CANDLE RUSH BOT CONFIGURATION
# Used by: ./candle-rush-bot (standalone) or ./bot-manager
# These env vars OVERRIDE the candle_rush section of config.yaml.
# Strategy: ALL assets × ALL intervals × N candles per round
# =====================================================

# Private key for Candle Rush Bot (can use same as OWNER_PRIVATE_KEY)
# This wallet will place all bets directly
# Omit to enter at runtime. Falls back to OWNER_PRIVATE_KEY.
# PRIVATE_KEY=

# Config file path (optional, defaults to config.yaml)
# CONFIG_FILE=config.yaml

# Assets to bet on (comma-separated)
# Each asset gets GREEN + RED bets per candle per interval
ASSETS=BTC,ETH,SOL

# Bet amount range (USDC per side, per asset, per candle)
# Total per round = amount × 2 × num_assets × candles × num_intervals
MIN_AMOUNT_USDC=0.1
MAX_AMOUNT_USDC=1.0

# Candle intervals (comma-separated: 300=5m, 900=15m, 1800=30m)
INTERVALS=300,900,1800

# Number of consecutive candles to bet on per interval (default: 5)
CANDLES_PER_INTERVAL=5

# Cooldown between interval batch transactions within a round (seconds)
COOLDOWN_MIN=10
COOLDOWN_MAX=30

# Broker ID for tracking
BROKER_ID=1

# =====================================================
# SLACK NOTIFICATIONS
# Send alerts when owner wallet balance drops below threshold
# =====================================================

# Slack Incoming Webhook URL (create at https://api.slack.com/messaging/webhooks)
# SLACK_WEBHOOK_URL=

# Low balance thresholds (triggers Slack alert when below)
LOW_BALANCE_THRESHOLD_USDC=50
LOW_BALANCE_THRESHOLD_MON=1
