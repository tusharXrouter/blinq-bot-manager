# Binaries — anchored to repo root so the matching cmd/<name>/ source
# directories don't get accidentally ignored too. The unanchored form
# (e.g. `bot-manager`) silently swallowed cmd/bot/, cmd/manager/, etc. on
# the previous restructure; we don't want a rerun of that.
/bet-bot-manager
/sweep-manager
/test-bet-bot-manager
*.exe
*.exe~
*.dll
*.so
*.dylib

# OS files
.DS_Store

# Test binary
*.test

# Output of go coverage
*.out

# Dependency directories
vendor/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Environment
.env
.env.local
.old

# Data files with sensitive info
data/wallets.json
/backup/*

# Build
/build/
/dist/


